# Backend environment (python-decouple). Copy to `.env` and adjust.
# Required values are validated at startup (fail-fast). See ARCHITECTURE.md §1.

# --- Required ---------------------------------------------------------------
# Option A) Local MongoDB via docker-compose (see docker-compose.yml at repo root)
DB_URL=mongodb://localhost:27017
# Option B) MongoDB Atlas connection string
# DB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=rps

# --- Optional ---------------------------------------------------------------
# Redis is only needed when scaling out (multiple workers). Leave empty for MVP.
# REDIS_URL=redis://localhost:6379/0

# Dev/demo CPU players. Set false for production or long-term public hosting.
# See docs/DEPLOY.md (production checklist).
ALLOW_CPU=true

# Comma-separated allowed CORS origins (defaults to Vite dev server).
# Caddy + Cloudflare Tunnel on a single public host: CORS change is usually unnecessary.
# Set explicit origins only when the frontend is served from a different host than the API.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Operational tunables (defaults shown; uncomment to override) -----------
# HOST_TRANSFER_GRACE_SEC=30
# GHOST_TTL_SEC=120
# ROOM_IDLE_TTL_SEC=1800
# ROOM_CREATE_RATE_MAX=10
# ROOM_CREATE_RATE_WINDOW_SEC=600
