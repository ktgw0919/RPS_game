# Copy to repo root as `Caddyfile` and replace <REPO_ROOT> with your clone path.
# Do not commit `Caddyfile` (machine-specific; see docs/DEPLOY.md).
#
# Local reverse proxy: Cloudflare Tunnel → :8080
# Serves frontend/dist and proxies API + WebSocket to uvicorn on :8000.
:8080 {
	root * <REPO_ROOT>/frontend/dist
	encode gzip

	@api path /rooms* /config* /health*
	handle @api {
		reverse_proxy 127.0.0.1:8000
	}

	handle /ws* {
		reverse_proxy 127.0.0.1:8000
	}

	handle {
		try_files {path} /index.html
		file_server
	}
}
